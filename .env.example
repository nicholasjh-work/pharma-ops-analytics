# ── Local PostgreSQL (development) ────────────────────────────
PG_HOST=localhost
PG_USER=nickhidalgo
PG_PASSWORD=
PG_DATABASE=pharma_ops

# ── Snowflake ─────────────────────────────────────────────────
# Sign up: https://signup.snowflake.com (30-day free trial, $400 credit)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=PHARMA_OPS
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=ACCOUNTADMIN

# ── Google BigQuery ───────────────────────────────────────────
# Free tier: 1 TB/month queries, 10 GB storage
# 1. Create project at https://console.cloud.google.com
# 2. Enable BigQuery API
# 3. Create service account key (JSON) and save locally
BIGQUERY_PROJECT=
BIGQUERY_DATASET=pharma_ops
BIGQUERY_KEYFILE=

# ── Databricks ────────────────────────────────────────────────
# Community Edition: https://community.cloud.databricks.com
# Or workspace trial: https://www.databricks.com/try-databricks
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=pharma_ops
